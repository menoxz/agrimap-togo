    "cooperative_buffer_km": 10,
    "crs_analysis": "EPSG:32631",
    "n_cooperatives": 55,
    "n_farms": 737
  },
  "inputs": [
    "cooperatives",
    "grandes_exploitations",
    "petites_exploitations",
    "plantations",
    "geoBoundaries-TGO-ADM2"
